# SMS Center configuration — copy relevant values into Vercel → Settings →
# Environment Variables (do NOT commit real secrets). See SMS_SETUP.md.

# --- Always required ---
SMS_SEND_PASSWORD=choose-a-strong-secret
SMS_PROVIDER=africastalking   # africastalking | twilio | mtn

# --- Africa's Talking ---
AT_API_KEY=
AT_USERNAME=sandbox           # "sandbox" for testing, your username in production
AT_ENV=sandbox                # sandbox | production
AT_SENDER_ID=                 # optional registered sender ID / short code

# --- Twilio (only if SMS_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- MTN API Marketplace / MADAPI (only if SMS_PROVIDER=mtn) ---
# Copy every URL/key EXACTLY from your approved app's SMS product docs.
MTN_CONSUMER_KEY=
MTN_CONSUMER_SECRET=
MTN_SUBSCRIPTION_KEY=          # Ocp-Apim-Subscription-Key
MTN_TOKEN_URL=                 # OAuth2 client_credentials token endpoint
MTN_SMS_URL=                   # SMS outbound "send" endpoint
MTN_SENDER_ID=                 # assigned sender ID / short code
