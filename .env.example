# SMS Center configuration — copy relevant values into Vercel → Settings →
# Environment Variables (do NOT commit real secrets). See SMS_SETUP.md.

# --- Always required ---
SMS_SEND_PASSWORD=choose-a-strong-secret
SMS_PROVIDER=africastalking   # africastalking | twilio

# --- Africa's Talking ---
AT_API_KEY=
AT_USERNAME=sandbox           # "sandbox" for testing, your username in production
AT_ENV=sandbox                # sandbox | production
AT_SENDER_ID=                 # optional registered sender ID / short code

# --- Twilio (only if SMS_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
